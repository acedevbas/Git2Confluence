# OpenAPI History Tracker - Environment Variables
# Copy this file to .env and fill in your values

# Redis Configuration
REDIS_HOST=192.168.1.56
REDIS_PORT=3338
REDIS_DB=0
# REDIS_PASSWORD=

# GitLab Configuration
GITLAB_URL=https://git.vseinstrumenti.net
GITLAB_TOKEN=your-gitlab-token-here
PROJECT_PATH=logistic/retail/rms/rms-api
GITLAB_SSL_VERIFY=false

# Target Endpoint to Analyze
TARGET_ENDPOINT=POST /orders/products

# Processing Options
MR_LIMIT=1000
FLUSH_CACHE_ON_START=false

# Regression Filter
GRACE_PERIOD_DAYS=7
FILTER_TEMPORARY_REGRESSIONS=true
SHOW_REGRESSION_DETAILS=true
MIN_REGRESSION_DURATION_HOURS=1.0

# Jira Integration
JIRA_BASE_URL=https://jira.vseinstrumenti.net/browse

# Confluence Integration (optional)
CONFLUENCE_BASE_URL=https://kb.vseinstrumenti.ru
CONFLUENCE_TOKEN=your-confluence-token-here
CONFLUENCE_SPACE_KEY=API
# CONFLUENCE_PARENT_PAGE_ID=12345
PUBLISH_TO_CONFLUENCE=false
